# ==== App ====
APP_ENV=development
LOG_LEVEL=INFO

# ==== Database ====
DATABASE_URL=sqlite+aiosqlite:///./myhome_vision.db
# 本番: DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/myhome_vision

# ==== Redis / Queue ====
REDIS_URL=redis://localhost:6379/0

# ==== Feature flags ====
# Kling AI は既定OFF (Dark Launch)。本採用時に true に切替
KLING_ENABLED=false

# ==== Provider endpoints ====
# ComfyUI: 国内 or Runpod Serverless
COMFYUI_ENDPOINT=http://localhost:8188
COMFYUI_API_KEY=

# Viggle (米国)
VIGGLE_ENDPOINT=https://api.viggle.ai/v1
VIGGLE_API_KEY=

# Runway Act One (米国)
RUNWAY_ENDPOINT=https://api.runwayml.com/v1
RUNWAY_API_KEY=

# Kling AI (Dark Launch)
KLING_ENDPOINT=https://api.klingai.com/v1
KLING_API_KEY=

# ==== Over-generation ====
OVERGEN_MULTIPLIER=2.0
DISPLAYED_PATTERNS=4

# ==== Quality gate thresholds ====
QUALITY_ARCFACE_MIN=0.65
QUALITY_POSE_MIN=0.70
QUALITY_UNCANNY_MAX=0.3

# ==== Circuit breaker ====
CB_ERROR_RATE_THRESHOLD=0.2
CB_WINDOW_SECONDS=300
CB_COOLDOWN_SECONDS=600

# ==== Anonymization ====
ANON_SALT=replace-me-with-random-long-string
FAILED_LOG_RETENTION_DAYS=730
